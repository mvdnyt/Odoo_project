<odoo>
    <!-- FORM VIEW: Agent's Phone-Call Entry Interface -->
    <record id="tourism_booking_view_form" model="ir.ui.view">
        <field name="name">tourism.booking.form</field>
        <field name="model">tourism.booking</field>
        <field name="arch" type="xml">
            <form>
                <!-- Control Header Panel: Workflow States & Control Actions -->
                <header>
                    <button name="action_confirm" string="Confirm Booking" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_cancel" string="Cancel Booking" type="object" invisible="state not in ['draft', 'confirmed']"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    
                    <!-- Main Context Blocks -->
                    <group>
                        <!-- Group 1: Customer Intake Specifications -->
                        <group string="Customer Profiling">
                            <field name="contact_name" placeholder="e.g., John Doe"/>
                            <field name="whatsapp_number" placeholder="e.g., +971 50 000 0000"/>
                            <field name="booking_date"/>
                            <separator string="Demographics"/>
                            <field name="group_size"/>
                            <field name="has_infants"/>
                        </group>
                        
                        <!-- Group 2: Package Selections & Live Meta Records -->
                        <group string="Tour Package &amp; Logistics">
                            <field name="package_id" options="{'no_create': True, 'no_open': False}"/>
                            <field name="hotel_star_rating"/>
                            <field name="boarding_type"/>
                            <separator string="Vehicle Dispatch Parameters"/>
                            <field name="transport_type"/>
                            <field name="vehicle_id" invisible="transport_type != 'internal'" required="transport_type == 'internal'" placeholder="Assign agency bus/van..."/>
                            <field name="vehicle_reg_no" invisible="transport_type != 'internal'"/>
                        </group>
                    </group>

                    <!-- Interactive Notebook Tab Areas -->
                    <notebook>
                        <!-- Tab 1: Operational Warning Output Feed -->
                        <page string="Logistics &amp; Safety Notes">
                            <group>
                                <field name="operational_notes" readonly="1" class="text-danger fw-bold"/>
                            </group>
                            <!-- Infant Safety Contacts Block: Revealed dynamically if flag is true -->
                            <group string="Mandatory Infant Safety Escort Registration Contacts" invisible="not has_infants">
                                <field name="emergency_phone_1" placeholder="First Emergency Number" required="has_infants"/>
                                <field name="emergency_phone_2" placeholder="Second Emergency Number" required="has_infants"/>
                                <field name="emergency_phone_3" placeholder="Third Emergency Number" required="has_infants"/>
                            </group>
                        </page>

                        <!-- Tab 2: Financial Summary Panels -->
                        <page string="Financial Audit Summary">
                            <group class="oe_subtotal_footer oe_right">
                                <field name="gross_amount" widget="monetary" options="{'currency_field': 'company_currency'}"/>
                                <field name="discount"/>
                                <div class="oe_subtotal_footer_separator oe_inline o_td_label">
                                    <label for="total_amount"/>
                                </div>
                                <field name="total_amount" nolabel="1" class="oe_subtotal_footer_separator" widget="monetary" options="{'currency_field': 'company_currency'}"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                
                <!-- Chatter Log Feed (Bottom Audit Trail) -->
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- LIST VIEW: Main Operational Ledger -->
    <record id="tourism_booking_view_list" model="ir.ui.view">
        <field name="name">tourism.booking.list</field>
        <field name="model">tourism.booking</field>
        <field name="arch" type="xml">
            <list decoration-info="state == 'draft'" decoration-success="state == 'confirmed'" decoration-muted="state == 'cancelled'">
                <field name="name" string="Folder ID"/>
                <field name="contact_name"/>
                <field name="whatsapp_number"/>
                <field name="booking_date"/>
                <field name="group_size" string="Pax"/>
                <field name="package_id"/>
                <field name="transport_type" string="Logistics Routing"/>
                <field name="total_amount" sum="Total Gross Revenue Pool"/>
                <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-success="state == 'confirmed'"/>
            </list>
        </field>
    </record>

    <!-- WINDOW ACTION TRIGGER -->
    <record id="tourism_booking_action" model="ir.actions.act_window">
        <field name="name">Agent Bookings Desk</field>
        <field name="res_model">tourism.booking</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Initiate a new client booking file!
            </p><p>
                Capture details over the phone. Odoo will automatically handle vehicle routing metrics.
            </p>
        </field>
    </record>


</odoo>
