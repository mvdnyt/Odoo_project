<odoo>
    <record id="res_users_view_form_inherit_tourism" model="ir.ui.view">
        <field name="name">res.users.form.inherit.tourism</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Assigned Tour Bookings" groups="base.group_no_one">
                    <field name="tour_booking_ids" readonly="1">
                        <list>
                            <field name="name" string="Booking Ref"/>
                            <field name="contact_name"/>
                            <field name="booking_date"/>
                            <field name="group_size"/>
                            <field name="total_amount"/>
                            <field name="state" widget="badge"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>
</odoo>