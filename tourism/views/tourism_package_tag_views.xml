<odoo>
    <!-- list VIEW: Direct Editable Spreadsheet List for Tags -->
    <record id="tourism_package_tag_view_list" model="ir.ui.view">
        <field name="name">tourism.package.tag.list</field>
        <field name="model">tourism.package.tag</field>
        <field name="arch" type="xml">
            <list string="Marketing Badges" editable="bottom" sample="1">
                <field name="name"/>
                <field name="color" widget="color_picker"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <!-- WINDOW ACTION TRIGGER -->
    <record id="tourism_package_tag_action" model="ir.actions.act_window">
        <field name="name">Marketing Badges</field>
        <field name="res_model">tourism.package.tag</field>
        <field name="view_mode">list</field>
    </record>


</odoo>
