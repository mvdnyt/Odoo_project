<odoo>
    <record id="tourism_vehicle_action" model="ir.actions.act_window">
        <field name="name">Vehicles</field>
        <field name="res_model">tourism.vehicle</field>
        <field name="view_mode">list,form,kanban</field>
    </record>

    <record id="tourism_vehicle_view_list" model="ir.ui.view">
        <field name="name">tourism.vehicle.list</field>
        <field name="model">tourism.vehicle</field>
        <field name="arch" type="xml">
            <list
                decoration-success="state == 'available'"
                decoration-warning="state == 'maintenance'"
                decoration-danger="state == 'retired'"
                decoration-info="state == 'on_trip'">
                <field name="name"/>
                <field name="license_plate"/>
                <field name="vehicle_type_id"/>
                <field name="capacity"/>
                <field name="ownership"/>
                <field name="driver_id"/>
                <field name="total_trips"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="tourism_vehicle_view_form" model="ir.ui.view">
        <field name="name">tourism.vehicle.form</field>
        <field name="model">tourism.vehicle</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <header>
                        <button name="action_set_available" type="object" string="Set Available"
                            invisible="state in ('available', 'on_trip', 'retired')"/>
                        <button name="action_set_maintenance" type="object" string="Send to Maintenance"
                            invisible="state in ('maintenance', 'retired')"/>
                        <button name="action_retire" type="object" string="Retire Vehicle"
                            invisible="state == 'retired'"/>
                        <field name="state" widget="statusbar"
                            statusbar_visible="available,on_trip,maintenance,retired"
                            options="{'clickable': true}"/>
                    </header>
                    <h1>
                        <field name="name"/>
                    </h1>
                    <group>
                        <group>
                            <field name="license_plate"/>
                            <field name="vehicle_type_id"/>
                            <field name="capacity"/>
                            <field name="driver_id"/>
                        </group>
                        <group>
                            <field name="ownership"/>
                            <field name="partner_id" invisible="ownership == 'internal'"/>
                            <field name="commission_rate" invisible="ownership == 'internal'"/>
                            <field name="total_trips"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Trips">
                            <field name="trip_ids" readonly="state == 'retired'">
                                <list>
                                    <field name="name"/>
                                    <field name="trip_date"/>
                                    <field name="destination"/>
                                    <field name="passenger_count"/>
                                    <field name="group_type"/>
                                    <field name="state"/>
                                </list>
                            </field>
                        </page>
                        <page string="Maintenance">
                            <group>
                                <field name="last_service_date"/>
                                <field name="next_service_date"/>
                                <field name="notes"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="tourism_vehicle_view_kanban" model="ir.ui.view">
        <field name="name">tourism.vehicle.kanban</field>
        <field name="model">tourism.vehicle</field>
        <field name="arch" type="xml">
            <kanban default_group_by="vehicle_type_id">
                <field name="state"/>
                <field name="capacity"/>
                <templates>
                    <t t-name="card">
                        <field name="name"/>
                        <field name="license_plate"/>
                        <field name="ownership"/>
                        <t t-if="record.state.raw_value == 'available'">
                            <div><span>✅ Available | Seats: </span><field name="capacity"/></div>
                        </t>
                        <t t-if="record.state.raw_value == 'on_trip'">
                            <div><span>🚌 On Trip</span></div>
                        </t>
                        <t t-if="record.state.raw_value == 'maintenance'">
                            <div><span>🔧 Under Maintenance</span></div>
                        </t>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>
</odoo>
