<odoo>
    <!-- Inherit and extend the core Agent Booking Form View -->
    <record id="tourism_booking_view_form_inherit_accounts" model="ir.ui.view">
        <field name="name">tourism.booking.form.inherit.accounts</field>
        <field name="model">tourism.booking</field>
        <field name="inherit_id" ref="tourism.tourism_booking_view_form"/>
        <field name="arch" type="xml">
            
            <!-- 1. Inject the invoicing button into the header control panel -->
            <xpath expr="//header" position="inside">
                <button name="action_create_invoice" 
                        string="Create Invoice" 
                        type="object" 
                        class="oe_highlight" 
                        invisible="state != 'confirmed' or invoice_count &gt; 0"/>
            </xpath>

            <!-- 2. Inject the Accounting Smart-Button at the top right of the sheet -->
            <xpath expr="//sheet" position="inside">
                <div class="oe_button_box" name="button_box">
                    <button name="action_create_invoice" 
                            type="object" 
                            class="oe_stat_button" 
                            icon="fa-pencil-square-o" 
                            invisible="invoice_count == 0">
                        <field name="invoice_count" widget="statinfo" string="Invoices"/>
                    </button>
                </div>
            </xpath>

        </field>
    </record>
</odoo>