<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="tourism_booking_view_form_invoice" model="ir.ui.view">
        <field name="name">tourism.booking.form.invoice</field>
        <field name="model">tourism.booking</field>
        <field name="inherit_id" ref="dubai_tourism.tourism_booking_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <field name="invoice_id" invisible="1"/>
                <button class="oe_stat_button" type="object" name="action_view_invoice"
                        icon="fa-pencil-square-o" invisible="not invoice_id">
                    <span class="o_stat_text">Invoice</span>
                </button>
            </xpath>
        </field>
    </record>
</odoo>
