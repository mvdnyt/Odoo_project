<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="tourism_transport_assignment_action" model="ir.actions.act_window">
        <field name="name">Transport Assignments</field>
        <field name="res_model">tourism.transport.assignment</field>
        <field name="view_mode">list,kanban,calendar,graph,pivot,form</field>
    </record>

    <record id="tourism_transport_utilization_action" model="ir.actions.act_window">
        <field name="name">Fleet Utilization</field>
        <field name="res_model">tourism.transport.assignment</field>
        <field name="view_mode">pivot,graph,list</field>
        <field name="context">{'search_default_internal': 1, 'search_default_group_vehicle': 1}</field>
    </record>

    <record id="tourism_transport_assignment_view_graph" model="ir.ui.view">
        <field name="name">tourism.transport.assignment.graph</field>
        <field name="model">tourism.transport.assignment</field>
        <field name="arch" type="xml">
            <graph string="Transport" sample="1">
                <field name="vehicle_id"/>
                <field name="passenger_count" type="measure"/>
                <field name="commission_amount" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="tourism_transport_assignment_view_pivot" model="ir.ui.view">
        <field name="name">tourism.transport.assignment.pivot</field>
        <field name="model">tourism.transport.assignment</field>
        <field name="arch" type="xml">
            <pivot string="Transport" sample="1">
                <field name="vehicle_id" type="row"/>
                <field name="transport_type" type="col"/>
                <field name="passenger_count" type="measure"/>
                <field name="commission_amount" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="tourism_transport_assignment_view_list" model="ir.ui.view">
        <field name="name">tourism.transport.assignment.list</field>
        <field name="model">tourism.transport.assignment</field>
        <field name="arch" type="xml">
            <list decoration-info="state == 'ongoing'"
                  decoration-success="state == 'done'"
                  decoration-muted="state == 'cancelled'">
                <field name="name"/>
                <field name="booking_id"/>
                <field name="transport_type"/>
                <field name="vehicle_id"/>
                <field name="taxi_company_id"/>
                <field name="passenger_count"/>
                <field name="cost" widget="monetary"/>
                <field name="commission_amount" widget="monetary"/>
                <field name="currency_id" column_invisible="1"/>
                <field name="state" widget="badge"/>
                <button name="action_start" type="object" string="Start" icon="fa-play" invisible="state != 'planned'"/>
                <button name="action_done" type="object" string="Done" icon="fa-check" invisible="state != 'ongoing'"/>
            </list>
        </field>
    </record>

    <record id="tourism_transport_assignment_view_kanban" model="ir.ui.view">
        <field name="name">tourism.transport.assignment.kanban</field>
        <field name="model">tourism.transport.assignment</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" sample="1">
                <field name="state"/>
                <field name="currency_id"/>
                <templates>
                    <t t-name="card">
                        <div class="fw-bold"><field name="name"/></div>
                        <field name="booking_id"/>
                        <div class="text-muted"><field name="transport_type"/></div>
                        <div class="mt-1"><i class="fa fa-users me-1"/><field name="passenger_count"/></div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="tourism_transport_assignment_view_calendar" model="ir.ui.view">
        <field name="name">tourism.transport.assignment.calendar</field>
        <field name="model">tourism.transport.assignment</field>
        <field name="arch" type="xml">
            <calendar string="Pick-ups" date_start="pickup_datetime" color="transport_type" mode="week">
                <field name="booking_id"/>
                <field name="vehicle_id"/>
            </calendar>
        </field>
    </record>

    <record id="tourism_transport_assignment_view_search" model="ir.ui.view">
        <field name="name">tourism.transport.assignment.search</field>
        <field name="model">tourism.transport.assignment</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="booking_id"/>
                <field name="vehicle_id"/>
                <field name="taxi_company_id"/>
                <filter name="internal" string="Internal Fleet" domain="[('transport_type', '=', 'internal')]"/>
                <filter name="external" string="Third-Party" domain="[('transport_type', '=', 'external')]"/>
                <separator/>
                <filter name="done" string="Completed" domain="[('state', '=', 'done')]"/>
                <group>
                    <filter name="group_vehicle" string="Vehicle" context="{'group_by': 'vehicle_id'}"/>
                    <filter name="group_type" string="Type" context="{'group_by': 'transport_type'}"/>
                    <filter name="group_state" string="Status" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="tourism_transport_assignment_view_form" model="ir.ui.view">
        <field name="name">tourism.transport.assignment.form</field>
        <field name="model">tourism.transport.assignment</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_start" type="object" string="Start Trip" class="btn-primary" invisible="state != 'planned'"/>
                    <button name="action_done" type="object" string="Mark Done" invisible="state != 'ongoing'"/>
                    <button name="action_cancel" type="object" string="Cancel" invisible="state in ('done', 'cancelled')"/>
                    <field name="state" widget="statusbar" statusbar_visible="planned,ongoing,done"/>
                </header>
                <sheet>
                    <div class="oe_title"><h1><field name="name" readonly="1"/></h1></div>
                    <group>
                        <group>
                            <field name="booking_id"/>
                            <field name="customer_id"/>
                            <field name="transport_type" widget="radio" options="{'horizontal': true}"/>
                            <field name="vehicle_id" invisible="transport_type != 'internal'"
                                   required="transport_type == 'internal'"/>
                            <field name="taxi_company_id" invisible="transport_type != 'external'"
                                   required="transport_type == 'external'"/>
                            <field name="passenger_count"/>
                        </group>
                        <group>
                            <field name="pickup_datetime"/>
                            <field name="pickup_location"/>
                            <field name="dropoff_location"/>
                            <field name="cost" widget="monetary"/>
                            <field name="commission_rate"/>
                            <field name="commission_amount" widget="monetary"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
