<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="tourism_departure_action" model="ir.actions.act_window">
        <field name="name">Departures</field>
        <field name="res_model">tourism.departure</field>
        <field name="view_mode">calendar,list,kanban,form</field>
    </record>

    <record id="tourism_departure_view_list" model="ir.ui.view">
        <field name="name">tourism.departure.list</field>
        <field name="model">tourism.departure</field>
        <field name="arch" type="xml">
            <list decoration-success="seats_available > 0 and state in ('scheduled','confirmed')"
                  decoration-danger="is_full"
                  decoration-muted="state in ('done','cancelled')">
                <field name="name"/>
                <field name="package_id"/>
                <field name="departure_date"/>
                <field name="guide_id"/>
                <field name="seats_booked"/>
                <field name="capacity"/>
                <field name="seats_available"/>
                <field name="revenue" widget="monetary"/>
                <field name="currency_id" column_invisible="1"/>
                <field name="is_full" column_invisible="1"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="tourism_departure_view_kanban" model="ir.ui.view">
        <field name="name">tourism.departure.kanban</field>
        <field name="model">tourism.departure</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" sample="1" class="o_tourism_kanban">
                <field name="is_full"/>
                <templates>
                    <t t-name="card">
                        <widget name="web_ribbon" title="Full" bg_color="text-bg-danger" invisible="not is_full"/>
                        <div class="fw-bold"><field name="name"/></div>
                        <div class="mt-1"><i class="fa fa-user me-1"/><field name="guide_id"/></div>
                        <div class="mt-2">
                            <span class="badge text-bg-info"><field name="seats_booked"/> / <field name="capacity"/> seats</span>
                            <span class="badge text-bg-success" invisible="is_full"><field name="seats_available"/> left</span>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="tourism_departure_view_calendar" model="ir.ui.view">
        <field name="name">tourism.departure.calendar</field>
        <field name="model">tourism.departure</field>
        <field name="arch" type="xml">
            <calendar string="Departures" date_start="departure_date" color="package_id" mode="month">
                <field name="package_id" filters="1"/>
                <field name="seats_booked"/>
                <field name="guide_id"/>
            </calendar>
        </field>
    </record>

    <record id="tourism_departure_view_form" model="ir.ui.view">
        <field name="name">tourism.departure.form</field>
        <field name="model">tourism.departure</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_confirm" type="object" string="Confirm" class="btn-primary" invisible="state != 'scheduled'"/>
                    <button name="action_depart" type="object" string="Mark Departed" invisible="state != 'confirmed'"/>
                    <button name="action_done" type="object" string="Mark Done" invisible="state != 'departed'"/>
                    <button name="action_cancel" type="object" string="Cancel" invisible="state in ('done','cancelled')"/>
                    <field name="state" widget="statusbar" statusbar_visible="scheduled,confirmed,departed,done"/>
                </header>
                <sheet>
                    <widget name="web_ribbon" title="Full" bg_color="text-bg-danger" invisible="not is_full"/>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" type="object" name="action_view_bookings" icon="fa-suitcase">
                            <field name="seats_booked" widget="statinfo" string="Seats Booked"/>
                        </button>
                    </div>
                    <div class="oe_title"><h1><field name="name" readonly="1"/></h1></div>
                    <group>
                        <group>
                            <field name="package_id"/>
                            <field name="departure_date"/>
                            <field name="guide_id"/>
                            <field name="vehicle_id"/>
                        </group>
                        <group>
                            <field name="capacity"/>
                            <field name="seats_booked"/>
                            <field name="seats_available"/>
                            <field name="revenue" widget="monetary"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Bookings">
                            <field name="booking_ids" readonly="1">
                                <list>
                                    <field name="name"/>
                                    <field name="customer_id"/>
                                    <field name="group_size"/>
                                    <field name="amount_total" widget="monetary"/>
                                    <field name="currency_id" column_invisible="1"/>
                                    <field name="state" widget="badge"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
</odoo>
