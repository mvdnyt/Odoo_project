<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record model="ir.module.category" id="module_category_tourism">
        <field name="name">Dubai Tourism</field>
        <field name="sequence">70</field>
    </record>

    <record model="res.groups.privilege" id="res_groups_privilege_tourism">
        <field name="name">Dubai Tourism</field>
        <field name="sequence">10</field>
        <field name="category_id" ref="module_category_tourism"/>
    </record>

    <!-- Agent: a tour sales agent -->
    <record id="group_tourism_agent" model="res.groups">
        <field name="name">Agent</field>
        <field name="sequence">10</field>
        <field name="privilege_id" ref="res_groups_privilege_tourism"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <!-- Manager: implies Agent; admin is a Manager -->
    <record id="group_tourism_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="sequence">20</field>
        <field name="privilege_id" ref="res_groups_privilege_tourism"/>
        <field name="implied_ids" eval="[(4, ref('group_tourism_agent'))]"/>
        <field name="user_ids" eval="[(4, ref('base.user_admin'))]"/>
    </record>

    <data noupdate="1">
        <!-- Agents see the bookings they own; managers see everything -->
        <record id="tourism_booking_rule_agent" model="ir.rule">
            <field name="name">Tour Booking: agent sees own</field>
            <field name="model_id" ref="model_tourism_booking"/>
            <field name="domain_force">[('salesperson_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_tourism_agent'))]"/>
        </record>
        <record id="tourism_booking_rule_manager" model="ir.rule">
            <field name="name">Tour Booking: manager sees all</field>
            <field name="model_id" ref="model_tourism_booking"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_tourism_manager'))]"/>
        </record>

        <!-- Portal customers see only their own bookings -->
        <record id="tourism_booking_rule_portal" model="ir.rule">
            <field name="name">Tour Booking: portal sees own</field>
            <field name="model_id" ref="model_tourism_booking"/>
            <field name="domain_force">[('customer_id', '=', user.partner_id.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
        </record>
    </data>
</odoo>
