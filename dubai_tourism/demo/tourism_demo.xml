<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- ============ Destinations ============ -->
        <record id="dest_burj" model="tourism.destination">
            <field name="name">Burj Khalifa</field>
            <field name="city">Dubai</field>
            <field name="color">4</field>
        </record>
        <record id="dest_desert" model="tourism.destination">
            <field name="name">Dubai Desert</field>
            <field name="city">Dubai</field>
            <field name="color">3</field>
        </record>
        <record id="dest_marina" model="tourism.destination">
            <field name="name">Dubai Marina</field>
            <field name="city">Dubai</field>
            <field name="color">10</field>
        </record>
        <record id="dest_old" model="tourism.destination">
            <field name="name">Old Dubai (Al Fahidi)</field>
            <field name="city">Dubai</field>
            <field name="color">2</field>
        </record>
        <record id="dest_palm" model="tourism.destination">
            <field name="name">Palm Jumeirah</field>
            <field name="city">Dubai</field>
            <field name="color">7</field>
        </record>

        <!-- ============ Tour packages ============ -->
        <record id="pkg_city" model="tourism.tour.package">
            <field name="name">Dubai City Highlights</field>
            <field name="code">CITY</field>
            <field name="category">city</field>
            <field name="duration_days">1</field>
            <field name="capacity">30</field>
            <field name="price_adult">250</field>
            <field name="price_child">125</field>
            <field name="destination_ids" eval="[(6, 0, [ref('dest_burj'), ref('dest_marina'), ref('dest_old')])]"/>
        </record>
        <record id="pkg_desert" model="tourism.tour.package">
            <field name="name">Desert Safari Adventure</field>
            <field name="code">DESERT</field>
            <field name="category">desert</field>
            <field name="duration_days">1</field>
            <field name="capacity">24</field>
            <field name="price_adult">300</field>
            <field name="price_child">150</field>
            <field name="destination_ids" eval="[(6, 0, [ref('dest_desert')])]"/>
        </record>
        <record id="pkg_marina" model="tourism.tour.package">
            <field name="name">Marina Luxury Cruise</field>
            <field name="code">CRUISE</field>
            <field name="category">cruise</field>
            <field name="duration_days">1</field>
            <field name="capacity">40</field>
            <field name="price_adult">200</field>
            <field name="price_child">100</field>
            <field name="is_featured" eval="True"/>
            <field name="promo_price">160</field>
            <field name="destination_ids" eval="[(6, 0, [ref('dest_marina'), ref('dest_palm')])]"/>
        </record>
        <record id="pkg_cultural" model="tourism.tour.package">
            <field name="name">Cultural Heritage Walk</field>
            <field name="code">CULT</field>
            <field name="category">cultural</field>
            <field name="duration_days">1</field>
            <field name="capacity">20</field>
            <field name="price_adult">180</field>
            <field name="price_child">90</field>
            <field name="destination_ids" eval="[(6, 0, [ref('dest_old')])]"/>
        </record>
        <record id="pkg_luxury" model="tourism.tour.package">
            <field name="name">Luxury Dubai Experience</field>
            <field name="code">LUX</field>
            <field name="category">luxury</field>
            <field name="duration_days">3</field>
            <field name="capacity">12</field>
            <field name="price_adult">1200</field>
            <field name="price_child">600</field>
            <field name="destination_ids" eval="[(6, 0, [ref('dest_burj'), ref('dest_palm'), ref('dest_marina')])]"/>
        </record>

        <!-- ============ People ============ -->
        <record id="cust_john" model="res.partner">
            <field name="name">John Carter</field>
            <field name="email">john.carter@example.com</field>
        </record>
        <record id="cust_maria" model="res.partner">
            <field name="name">Maria Lopez</field>
            <field name="email">maria.lopez@example.com</field>
        </record>
        <record id="cust_chen" model="res.partner">
            <field name="name">Wei Chen</field>
            <field name="email">wei.chen@example.com</field>
        </record>
        <record id="cust_ahmed" model="res.partner">
            <field name="name">Ahmed Nasser</field>
            <field name="email">ahmed.nasser@example.com</field>
        </record>
        <record id="taxi_company" model="res.partner">
            <field name="name">Dubai City Taxi Co.</field>
            <field name="is_company" eval="True"/>
            <field name="is_taxi_company" eval="True"/>
        </record>

        <!-- ============ Fleet ============ -->
        <record id="veh_bus1" model="tourism.vehicle">
            <field name="name">Mercedes Coach 01</field>
            <field name="vehicle_type">bus</field>
            <field name="license_plate">DXB-A-1001</field>
            <field name="seats">30</field>
        </record>
        <record id="veh_van1" model="tourism.vehicle">
            <field name="name">Toyota Hiace 01</field>
            <field name="vehicle_type">van</field>
            <field name="license_plate">DXB-B-2001</field>
            <field name="seats">14</field>
        </record>
        <record id="veh_van2" model="tourism.vehicle">
            <field name="name">Toyota Hiace 02</field>
            <field name="vehicle_type">van</field>
            <field name="license_plate">DXB-B-2002</field>
            <field name="seats">14</field>
        </record>

        <!-- ============ Bookings ============ -->
        <!-- Family (2 adults + 1 child) -> family discount kicks in -->
        <record id="bk_city_family" model="tourism.booking">
            <field name="customer_id" ref="cust_john"/>
            <field name="package_id" ref="pkg_city"/>
            <field name="departure_date">2026-07-10</field>
            <field name="adult_count">2</field>
            <field name="child_count">1</field>
            <field name="state">paid</field>
        </record>
        <!-- Group of 12 -> group discount kicks in -->
        <record id="bk_desert_group" model="tourism.booking">
            <field name="customer_id" ref="cust_maria"/>
            <field name="package_id" ref="pkg_desert"/>
            <field name="departure_date">2026-07-12</field>
            <field name="adult_count">12</field>
            <field name="child_count">0</field>
            <field name="state">confirmed</field>
        </record>
        <record id="bk_marina_draft" model="tourism.booking">
            <field name="customer_id" ref="cust_chen"/>
            <field name="package_id" ref="pkg_marina"/>
            <field name="departure_date">2026-07-15</field>
            <field name="adult_count">2</field>
            <field name="state">draft</field>
        </record>
        <record id="bk_luxury_done" model="tourism.booking">
            <field name="customer_id" ref="cust_ahmed"/>
            <field name="package_id" ref="pkg_luxury"/>
            <field name="departure_date">2026-06-20</field>
            <field name="adult_count">2</field>
            <field name="state">completed</field>
        </record>
        <record id="bk_cultural_family" model="tourism.booking">
            <field name="customer_id" ref="cust_john"/>
            <field name="package_id" ref="pkg_cultural"/>
            <field name="departure_date">2026-07-18</field>
            <field name="adult_count">4</field>
            <field name="child_count">2</field>
            <field name="state">paid</field>
        </record>

        <!-- ============ Transport ============ -->
        <!-- Internal bus for the desert group -->
        <record id="ta_desert_bus" model="tourism.transport.assignment">
            <field name="booking_id" ref="bk_desert_group"/>
            <field name="transport_type">internal</field>
            <field name="vehicle_id" ref="veh_bus1"/>
            <field name="passenger_count">12</field>
            <field name="pickup_location">Downtown Dubai</field>
            <field name="dropoff_location">Desert Camp</field>
            <field name="cost">800</field>
        </record>
        <!-- Third-party taxi for the small family group -> commission revenue -->
        <record id="ta_city_taxi" model="tourism.transport.assignment">
            <field name="booking_id" ref="bk_city_family"/>
            <field name="transport_type">external</field>
            <field name="taxi_company_id" ref="taxi_company"/>
            <field name="passenger_count">3</field>
            <field name="pickup_location">Hotel</field>
            <field name="dropoff_location">Burj Khalifa</field>
            <field name="cost">150</field>
            <field name="commission_rate">15</field>
        </record>
        <!-- Internal van for the luxury booking -->
        <record id="ta_luxury_van" model="tourism.transport.assignment">
            <field name="booking_id" ref="bk_luxury_done"/>
            <field name="transport_type">internal</field>
            <field name="vehicle_id" ref="veh_van1"/>
            <field name="passenger_count">2</field>
            <field name="state">done</field>
        </record>

        <!-- ============ Reviews ============ -->
        <record id="rev_luxury" model="tourism.review">
            <field name="booking_id" ref="bk_luxury_done"/>
            <field name="package_id" ref="pkg_luxury"/>
            <field name="customer_id" ref="cust_ahmed"/>
            <field name="rating">5</field>
            <field name="comment">Unforgettable experience, world-class service.</field>
        </record>
        <record id="rev_city" model="tourism.review">
            <field name="booking_id" ref="bk_city_family"/>
            <field name="package_id" ref="pkg_city"/>
            <field name="customer_id" ref="cust_john"/>
            <field name="rating">4</field>
            <field name="comment">Great overview of the city, kids loved it.</field>
        </record>

        <!-- ============ Tour guide ============ -->
        <record id="guide_sara" model="res.partner">
            <field name="name">Sara (Guide)</field>
            <field name="is_tour_guide" eval="True"/>
        </record>

        <!-- ============ Itinerary (for the city package) ============ -->
        <record id="itin_city_1" model="tourism.itinerary.line">
            <field name="package_id" ref="pkg_city"/>
            <field name="day_number">1</field>
            <field name="title">Morning: Burj Khalifa &amp; Downtown</field>
            <field name="destination_id" ref="dest_burj"/>
            <field name="description">At The Top observation deck and Dubai Fountain.</field>
        </record>
        <record id="itin_city_2" model="tourism.itinerary.line">
            <field name="package_id" ref="pkg_city"/>
            <field name="day_number">1</field>
            <field name="title">Afternoon: Marina &amp; Old Dubai</field>
            <field name="destination_id" ref="dest_marina"/>
            <field name="description">Marina walk, abra ride and the spice souk.</field>
        </record>

        <!-- ============ Scheduled departures ============ -->
        <record id="dep_city_jul" model="tourism.departure">
            <field name="package_id" ref="pkg_city"/>
            <field name="departure_date">2026-07-20</field>
            <field name="capacity">30</field>
            <field name="guide_id" ref="guide_sara"/>
            <field name="state">confirmed</field>
        </record>
        <record id="dep_desert_jul" model="tourism.departure">
            <field name="package_id" ref="pkg_desert"/>
            <field name="departure_date">2026-07-12</field>
            <field name="capacity">24</field>
            <field name="guide_id" ref="guide_sara"/>
            <field name="state">scheduled</field>
        </record>

        <!-- A booking attached to a scheduled departure -->
        <record id="bk_city_departure" model="tourism.booking">
            <field name="customer_id" ref="cust_chen"/>
            <field name="package_id" ref="pkg_city"/>
            <field name="departure_id" ref="dep_city_jul"/>
            <field name="departure_date">2026-07-20</field>
            <field name="adult_count">3</field>
            <field name="state">paid</field>
        </record>
    </data>
</odoo>
