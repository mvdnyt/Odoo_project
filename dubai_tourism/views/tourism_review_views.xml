<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="tourism_review_action" model="ir.actions.act_window">
        <field name="name">Reviews</field>
        <field name="res_model">tourism.review</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="tourism_review_view_list" model="ir.ui.view">
        <field name="name">tourism.review.list</field>
        <field name="model">tourism.review</field>
        <field name="arch" type="xml">
            <list>
                <field name="package_id"/>
                <field name="customer_id"/>
                <field name="rating" widget="priority"/>
                <field name="comment"/>
                <field name="create_date"/>
            </list>
        </field>
    </record>

    <record id="tourism_review_view_form" model="ir.ui.view">
        <field name="name">tourism.review.form</field>
        <field name="model">tourism.review</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="booking_id"/>
                            <field name="package_id"/>
                            <field name="customer_id"/>
                        </group>
                        <group>
                            <field name="rating" widget="priority"/>
                        </group>
                    </group>
                    <field name="comment" placeholder="What did the customer think?"/>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
