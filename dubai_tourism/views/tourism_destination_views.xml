<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="tourism_destination_action" model="ir.actions.act_window">
        <field name="name">Destinations</field>
        <field name="res_model">tourism.destination</field>
        <field name="view_mode">kanban,list,form</field>
    </record>

    <record id="tourism_destination_popularity_action" model="ir.actions.act_window">
        <field name="name">Destination Popularity</field>
        <field name="res_model">tourism.destination</field>
        <field name="view_mode">graph,list</field>
    </record>

    <record id="tourism_destination_view_graph" model="ir.ui.view">
        <field name="name">tourism.destination.graph</field>
        <field name="model">tourism.destination</field>
        <field name="arch" type="xml">
            <graph string="Destination Popularity" sample="1" type="bar">
                <field name="name"/>
                <field name="booking_count" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="tourism_destination_view_list" model="ir.ui.view">
        <field name="name">tourism.destination.list</field>
        <field name="model">tourism.destination</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="city"/>
                <field name="country_id"/>
                <field name="package_count"/>
                <field name="booking_count"/>
            </list>
        </field>
    </record>

    <record id="tourism_destination_view_kanban" model="ir.ui.view">
        <field name="name">tourism.destination.kanban</field>
        <field name="model">tourism.destination</field>
        <field name="arch" type="xml">
            <kanban sample="1" class="o_tourism_kanban">
                <templates>
                    <t t-name="card" class="flex-row">
                        <aside class="d-flex align-items-center me-2">
                            <field name="image" widget="image" options="{'img_class': 'object-fit-cover', 'size': [56, 56]}"/>
                        </aside>
                        <main>
                            <field name="name" class="fw-bold fs-5"/>
                            <div class="text-muted"><field name="city"/></div>
                            <div class="mt-1 text-muted">
                                <i class="fa fa-map-marker me-1"/><field name="booking_count"/> travellers
                            </div>
                        </main>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="tourism_destination_view_form" model="ir.ui.view">
        <field name="name">tourism.destination.form</field>
        <field name="model">tourism.destination</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <field name="image" widget="image" class="oe_avatar"/>
                    <div class="oe_title"><h1><field name="name" placeholder="Destination..."/></h1></div>
                    <group>
                        <group>
                            <field name="city"/>
                            <field name="country_id"/>
                            <field name="color" widget="color_picker"/>
                        </group>
                        <group>
                            <field name="package_count"/>
                            <field name="booking_count"/>
                        </group>
                    </group>
                    <field name="description" placeholder="About this destination..."/>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
