<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="tourism_vehicle_action" model="ir.actions.act_window">
        <field name="name">Fleet</field>
        <field name="res_model">tourism.vehicle</field>
        <field name="view_mode">kanban,list,form</field>
    </record>

    <record id="tourism_vehicle_view_list" model="ir.ui.view">
        <field name="name">tourism.vehicle.list</field>
        <field name="model">tourism.vehicle</field>
        <field name="arch" type="xml">
            <list decoration-muted="state == 'maintenance'" decoration-info="state == 'on_trip'">
                <field name="name"/>
                <field name="vehicle_type"/>
                <field name="license_plate"/>
                <field name="seats"/>
                <field name="driver_id"/>
                <field name="trips_done" optional="show"/>
                <field name="passengers_transported" optional="show"/>
                <field name="utilization" optional="show"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="tourism_vehicle_view_kanban" model="ir.ui.view">
        <field name="name">tourism.vehicle.kanban</field>
        <field name="model">tourism.vehicle</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" sample="1">
                <field name="state"/>
                <templates>
                    <t t-name="card">
                        <div class="fw-bold fs-5"><field name="name"/></div>
                        <div class="text-muted"><field name="vehicle_type"/> · <field name="license_plate"/></div>
                        <div class="mt-1"><i class="fa fa-users me-1"/><field name="seats"/> seats</div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="tourism_vehicle_view_form" model="ir.ui.view">
        <field name="name">tourism.vehicle.form</field>
        <field name="model">tourism.vehicle</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title"><h1><field name="name" placeholder="e.g. Mercedes Coach 01"/></h1></div>
                    <group>
                        <group>
                            <field name="vehicle_type"/>
                            <field name="license_plate"/>
                            <field name="seats"/>
                        </group>
                        <group>
                            <field name="driver_id"/>
                            <field name="state"/>
                            <field name="active"/>
                        </group>
                        <group string="Utilization">
                            <field name="trips_done"/>
                            <field name="passengers_transported"/>
                            <field name="utilization"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
